# Required — Claude API key for conversation and map generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Override the default Claude model for chat, sheet, insight (default: claude-sonnet-4-20250514)
# Read in: api/v2-chat/route.ts, api/sheet/route.ts, api/insight/route.ts
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — Alias used by canvas-regenerate (same model family as ANTHROPIC_MODEL; kept separate for historical reasons)
# Read in: api/canvas-regenerate/route.ts
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — Fast Haiku model used by the palette suggestion endpoint (default: claude-haiku-4-5-20251001)
# Read in: api/palette/route.ts
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# Optional — Upstash Redis for map caching
# KV_REST_API_URL=https://...upstash.io
# KV_REST_API_TOKEN=AX...

# Supabase — Auth + Database (required for Operate Mode)
# NEXT_PUBLIC_SUPABASE_URL=https://...supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Site URL for OG images and auth redirects
# NEXT_PUBLIC_SITE_URL=https://huma.earth

# Supabase Service Role — server-side admin access (cron jobs, bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cron secret — Vercel sends this to authenticate scheduled jobs
# CRON_SECRET=your-random-secret-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJ-ZBrEX6mruvYRKKxhCN...
# VAPID_PRIVATE_KEY=h7X4u7baztAp15v...
# VAPID_SUBJECT=mailto:hello@huma.earth
